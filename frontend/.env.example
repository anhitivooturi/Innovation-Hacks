# ============================================================================
# DevLog AI - Frontend Environment Configuration
# ============================================================================

# Backend API URL
# Production: https://devlog-backend-130030203761.us-central1.run.app
# Local dev: http://localhost:8000
VITE_API_BASE_URL=https://devlog-backend-130030203761.us-central1.run.app

# ============================================================================
# Firebase Configuration (REQUIRED for Live Mode)
# ============================================================================
# Get these values from: https://console.firebase.google.com/
# Project: project-5f6bf043-2561-48a7-af4
#
# If these are not configured, the app will automatically fall back to mock data.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=project-5f6bf043-2561-48a7-af4.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=project-5f6bf043-2561-48a7-af4
VITE_FIREBASE_STORAGE_BUCKET=project-5f6bf043-2561-48a7-af4.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# ============================================================================
# How to get Firebase credentials:
# ============================================================================
# 1. Go to https://console.firebase.google.com/
# 2. Select project: project-5f6bf043-2561-48a7-af4
# 3. Click on the gear icon → Project settings
# 4. Scroll down to "Your apps" section
# 5. Click on the web app or create a new one
# 6. Copy the config values from firebaseConfig object
# 7. Paste them above
#
# Once configured, the dashboard will automatically switch from Mock Mode to Live Mode
# and start receiving real-time updates from Firestore! 🔥
