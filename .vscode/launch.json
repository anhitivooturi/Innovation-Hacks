{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run DevLog Backend",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "server.app.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Run DevLog Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension"
      ],
      "outFiles": []
    }
  ],
  "compounds": [
    {
      "name": "Run DevLog Backend + Extension",
      "configurations": [
        "Run DevLog Backend",
        "Run DevLog Extension"
      ]
    }
  ]
}
