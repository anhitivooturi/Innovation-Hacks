{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run DevLog Local API",
      "type": "python",
      "request": "launch",
      "python": "C:\\Users\\natan\\AppData\\Local\\Programs\\Python\\Python313\\python.exe",
      "module": "uvicorn",
      "args": [
        "api.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/api/.env",
      "env": {
        "DEVLOG_PROJECT_ROOT": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Run DevLog Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension"
      ],
      "outFiles": []
    }
  ],
  "compounds": [
    {
      "name": "Run DevLog API + Extension",
      "configurations": [
        "Run DevLog Local API",
        "Run DevLog Extension"
      ]
    }
  ]
}
